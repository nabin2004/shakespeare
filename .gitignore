# OS
.DS_Store
Thumbs.db

# Processed corpus (parser output)
data/processed/

# Raw corpus downloads (do not commit large dumps by default)
data/raw/**/*.xml
data/raw/**/*.zip
# Local clone of upstream corpus (nested git checkout; not a submodule)
data/raw/shakespeare/
!data/raw/README.md
!data/raw/.gitkeep

# Generated triples (build artifacts)
data/triples/*.ttl
!data/triples/.gitkeep
